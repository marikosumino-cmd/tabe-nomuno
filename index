    .kpi-card.aka  .kpi-store { color: var(--aka); }
    .kpi-card.yura .kpi-store { color: var(--yura); }
    .kpi-card.futa .kpi-store { color: var(--futa); }
    .kpi-period { font-size: 11px; color: var(--muted); margin-bottom: 14px; }
    .kpi-label  { font-size: 11px; color: var(--muted); margin-bottom: 2px; margin-top: 14px; }
    .kpi-value  { font-family: 'Inter','Helvetica Neue',sans-serif; font-size: 30px; font-weight: 800; line-height: 1.1; }
    .kpi-value small { font-size: 16px; font-weight: 600; }
    .kpi-card.aka  .kpi-value { color: var(--aka); }
    .kpi-card.yura .kpi-value { color: var(--yura); }
    .kpi-card.futa .kpi-value { color: var(--futa); }
