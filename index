      background: linear-gradient(135deg, #6A0000 0%, #C62828 55%, #E53935 100%);
      color: #fff; padding: 36px 24px 28px;
    }
    .header-inner {
      max-width: 1200px; margin: 0 auto;
      display: flex; justify-content: space-between;
      align-items: flex-end; flex-wrap: wrap; gap: 16px;
    }
    .header-title { font-size: 12px; font-weight: 700; opacity: .8; letter-spacing: .12em; margin-bottom: 8px; }
