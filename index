    .cpa-card { background:#F8F9FA; border-radius:10px; padding:14px 16px; border:1px solid var(--border); }
    .cpa-store { font-size:12px; font-weight:700; margin-bottom:6px; }
    .cpa-nums  { display:flex; gap:12px; align-items:baseline; margin-bottom:8px; flex-wrap:wrap; }
    .cpa-num   { font-size:18px; font-weight:800; font-family:'Inter','Helvetica Neue',sans-serif; }
    .cpa-ratio { font-size:11px; color:var(--muted); font-weight:600; }
    .cpa-badge { display:inline-block; padding:3px 10px; border-radius:10px; font-size:11px; font-weight:700; margin-bottom:8px; }
    .cpa-badge.go   { background:#E8F5E9; color:#2E7D32; }
    .cpa-badge.warn { background:#FFF8E1; color:#F57F17; }
    .cpa-badge.stay { background:#FBE9E7; color:#BF360C; }
    .cpa-comment { font-size:11.5px; color:var(--muted); line-height:1.75; }
    @media (max-width:800px) { .cpa-judge-grid { grid-template-columns:1fr; } }
